class Solution {
    public ListNode revlist(ListNode head) {
        if(head == null || head.next == null) return head;
       ListNode newhead = revlist(head.next);
       head.next.next = head;
       head.next = null;
       return newhead;
    }
    public ListNode reverseList(ListNode head) {
       
       return revlist(head);
       
    }
}
