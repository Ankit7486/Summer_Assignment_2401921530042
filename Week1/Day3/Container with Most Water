class Solution {
    public int maxArea(int[] height) {
        int j= height.length-1 ,i =0;
        int maxarea = 0;
        
        while(i<j) {
            
            int min = Math.min(height[i],height[j]);
            maxarea = Math.max(maxarea,min*(j-i));
           if(height[i]< height[j]) i++;
           else j--;
        }
        return maxarea;
    }
}
