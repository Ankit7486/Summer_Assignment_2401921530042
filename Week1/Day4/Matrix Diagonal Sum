class Solution {
    public int diagonalSum(int[][] mat) {
        int sum1=0; int sum2=0;
       int r = mat.length;
       
       for(int i=0; i<r; i++) {
       
         sum1 += mat[i][i];
         sum2 += mat[i][r-i-1];
        }
       
       if(r%2 != 0) return (sum1+sum2)-mat[r/2][r/2];
       else return sum1+sum2;
    }
}
